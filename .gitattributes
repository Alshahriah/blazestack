# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.env text eol=lf

# Binary files — never diff or merge
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.zip binary
*.tar binary
*.gz binary
*.pdf binary

# Bun lockfile — treat as binary to avoid merge conflicts
bun.lock binary

# Mark generated files so GitHub collapses them in diffs
apps/web/worker-configuration.d.ts linguist-generated=true
apps/web/.react-router/**/* linguist-generated=true
