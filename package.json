{
  "name": "blazestack",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "db:setup": "bun run --cwd packages/db setup",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:seed": "bun run --cwd packages/db seed",
    "db:studio": "bun run --cwd packages/db studio",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run --cwd apps/api build",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "docs:sync": "bun run --cwd docs/site sync",
    "docs:dev": "bun run --cwd docs/site dev",
    "docs:build": "bun run --cwd docs/site build",
    "docs:preview": "bun run --cwd docs/site preview",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22",
    "lefthook": "^1.11.12",
    "turbo": "^2.5.3",
    "typescript": "^5.7.3"
  }
}
